generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripStatus {
  PENDING
  ACCEPTED
  ONGOING
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  createdAt DateTime @default(now())

  // trips    Trip[]
  location UserLocation?
}

model Driver {
  id          String  @id @default(uuid())
  name        String
  phone       String
  carModel    String
  carNumber   String
  isAvailable Boolean @default(false)

  // trips    Trip[]
  location DriverLocation?
}

